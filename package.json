    "migrate:dev": "prisma migrate dev --schema ./server/src/infrastructure/database/prisma/schema.prisma",
    "migrate:reset": "prisma migrate reset --schema ./server/src/infrastructure/database/prisma/schema.prisma",
    "generate": "prisma generate --schema ./server/src/infrastructure/database/prisma/schema.prisma",
    "db:seed": "tsx ./server/src/infrastructure/database/prisma/seed.ts"
  },
